rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Safety Net: Deny everything by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Schema and structure validation helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isNumeric(val) {
      return val is int || val is float;
    }

    function isValidUserAccount(data) {
      return data.id is string
        && data.login is string
        && data.passwordHash is string
        && (data.role == 'admin' || data.role == 'manager')
        && data.createdAt is string;
    }

    function isValidClientInstallment(data) {
      return data.id is string
        && data.tenantId is string
        && data.firstName is string
        && data.lastName is string
        && data.inn is string
        && data.phoneModel is string
        && data.imei is string
        && isNumeric(data.phonePrice)
        && isNumeric(data.markupPercent)
        && isNumeric(data.totalRemaining)
        && data.payments is list;
    }

    // Users Collection Paths:
    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidId(userId) && isValidUserAccount(request.resource.data);
      allow delete: if true;
    }

    // Clients Collection Paths:
    match /clients/{clientId} {
      allow read: if true;
      allow create: if isValidId(clientId) && isValidClientInstallment(request.resource.data);
      allow update: if isValidId(clientId) && isValidClientInstallment(request.resource.data);
      allow delete: if true;
    }
  }
}
